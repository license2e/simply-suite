<tr data-ts-row>
  <input type="hidden" name="entries[ROW_INDEX][id]" value="">
  <td class="px-2 py-1.5">
    <input type="text" name="entries[ROW_INDEX][service_date]" value=""
      placeholder="MM/DD/YYYY"
      class="w-full px-2 py-1 border border-gray-300 rounded text-sm focus:outline-none focus:ring-1 focus:ring-slate-500">
  </td>
  <td class="px-2 py-1.5">
    <input type="text" name="entries[ROW_INDEX][item]" value=""
      placeholder="Item"
      class="w-full px-2 py-1 border border-gray-300 rounded text-sm focus:outline-none focus:ring-1 focus:ring-slate-500">
  </td>
  <td class="px-2 py-1.5">
    <input type="text" name="entries[ROW_INDEX][desc]" value=""
      placeholder="Description"
      class="w-full px-2 py-1 border border-gray-300 rounded text-sm focus:outline-none focus:ring-1 focus:ring-slate-500">
  </td>
  <td class="px-2 py-1.5">
    <input type="number" name="entries[ROW_INDEX][qty]" value="" step="0.5" min="0"
      placeholder="0"
      class="w-full px-2 py-1 border border-gray-300 rounded text-sm focus:outline-none focus:ring-1 focus:ring-slate-500">
  </td>
  <td class="px-2 py-1.5">
    <input type="text" name="entries[ROW_INDEX][cost]" value=""
      placeholder="0.00"
      class="w-full px-2 py-1 border border-gray-300 rounded text-sm focus:outline-none focus:ring-1 focus:ring-slate-500">
  </td>
  <td class="px-2 py-1.5 text-right text-sm text-gray-400" data-ts-total>—</td>
  <td class="px-2 py-1.5 text-center">
    <span class="px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-500">No</span>
  </td>
  <td class="px-2 py-1.5 text-center">
    <button type="button" data-action="timesheet#removeRow"
      class="h-8 min-w-[2rem] text-gray-400 hover:text-red-500 text-xs transition-colors cursor-pointer">&times;</button>
  </td>
</tr>
