<% entry ||= {} %>
<% idx = index %>
<% invoiced = !!entry[:invoiced] %>
<tr data-ts-row class="<%= invoiced ? 'bg-gray-50 opacity-60' : 'hover:bg-gray-50' %>">
  <input type="hidden" name="entries[<%= idx %>][id]" value="<%= entry[:id] %>" <%= 'disabled' if invoiced %>>
  <td class="px-2 py-1.5">
    <input type="text" name="entries[<%= idx %>][service_date]" value="<%= fmt_date(entry[:service_date]) %>"
      placeholder="MM/DD/YYYY" <%= 'disabled' if invoiced %>
      class="w-full px-2 py-1 border border-gray-300 rounded text-sm focus:outline-none focus:ring-1 focus:ring-slate-500 disabled:bg-transparent disabled:border-transparent disabled:text-gray-500">
  </td>
  <td class="px-2 py-1.5">
    <input type="text" name="entries[<%= idx %>][item]" value="<%= entry[:item] %>"
      placeholder="Item" <%= 'disabled' if invoiced %>
      class="w-full px-2 py-1 border border-gray-300 rounded text-sm focus:outline-none focus:ring-1 focus:ring-slate-500 disabled:bg-transparent disabled:border-transparent disabled:text-gray-500">
  </td>
  <td class="px-2 py-1.5">
    <input type="text" name="entries[<%= idx %>][desc]" value="<%= entry[:desc] %>"
      placeholder="Description" <%= 'disabled' if invoiced %>
      class="w-full px-2 py-1 border border-gray-300 rounded text-sm focus:outline-none focus:ring-1 focus:ring-slate-500 disabled:bg-transparent disabled:border-transparent disabled:text-gray-500">
  </td>
  <td class="px-2 py-1.5">
    <input type="number" name="entries[<%= idx %>][qty]" value="<%= entry[:qty] %>" step="0.5" min="0"
      placeholder="0" <%= 'disabled' if invoiced %>
      data-action="input->timesheet#updateTotal" data-ts-qty
      class="w-full px-2 py-1 border border-gray-300 rounded text-sm focus:outline-none focus:ring-1 focus:ring-slate-500 disabled:bg-transparent disabled:border-transparent disabled:text-gray-500">
  </td>
  <td class="px-2 py-1.5">
    <input type="text" name="entries[<%= idx %>][cost]" value="<%= fmt_money(entry[:cost]) %>"
      placeholder="0.00" <%= 'disabled' if invoiced %>
      data-action="input->timesheet#updateTotal" data-ts-cost
      class="w-full px-2 py-1 border border-gray-300 rounded text-sm focus:outline-none focus:ring-1 focus:ring-slate-500 disabled:bg-transparent disabled:border-transparent disabled:text-gray-500">
  </td>
  <td class="px-2 py-1.5 text-right text-sm text-gray-700 font-medium" data-ts-total>
    <% if entry[:qty].to_s.empty? || entry[:cost].to_s.empty? %>&mdash;<% else %>$<%= fmt_line_total(entry) %><% end %>
  </td>
  <td class="px-2 py-1.5 text-center">
    <% if invoiced %>
      <span class="px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-700">Yes</span>
    <% else %>
      <span class="px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-500">No</span>
    <% end %>
  </td>
  <td class="px-2 py-1.5 text-center">
    <% unless invoiced %>
      <input type="hidden" name="delete_entries[]" value="<%= entry[:id] %>" disabled data-ts-delete>
      <button type="button" data-action="timesheet#removeRow"
        class="h-8 min-w-[2rem] text-gray-400 hover:text-red-500 text-xs transition-colors cursor-pointer">&times;</button>
    <% end %>
  </td>
</tr>
