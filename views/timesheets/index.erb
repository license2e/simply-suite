<div class="max-w-2xl">
  <% if @clients.empty? %>
    <p class="text-sm text-gray-500">No clients yet. <a href="/clients/create" class="underline text-slate-600">Create one.</a></p>
  <% else %>
    <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
      <table class="w-full text-sm">
        <thead class="bg-gray-50 border-b border-gray-200">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Client</th>
            <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Entries</th>
            <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Uninvoiced</th>
            <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% @clients.each do |client| %>
            <% entries = Timesheet.where(client_id: client.id).all %>
            <% uninvoiced = entries.count { |e| !e.invoiced } %>
            <tr class="hover:bg-gray-50">
              <td class="px-4 py-3 font-medium text-gray-900"><%= client.name %></td>
              <td class="px-4 py-3 text-right text-gray-500"><%= entries.count %></td>
              <td class="px-4 py-3 text-right">
                <% if uninvoiced > 0 %>
                  <span class="px-2 py-0.5 rounded text-xs font-medium bg-yellow-100 text-yellow-800"><%= uninvoiced %></span>
                <% else %>
                  <span class="text-gray-400">—</span>
                <% end %>
              </td>
              <td class="px-4 py-3 text-right">
                <a href="/timesheets/<%= client.client_key %>" class="text-xs text-slate-600 hover:text-slate-900 font-medium">Open</a>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>
