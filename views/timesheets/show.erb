<div class="space-y-4" data-controller="timesheet">

  <div class="flex items-center justify-between">
    <a href="/timesheets" class="text-sm text-slate-600 hover:text-slate-900">&larr; All Clients</a>
    <a href="/invoices/<%= @client.client_key %>"
      class="text-sm text-slate-600 hover:text-slate-900">Invoices &rarr;</a>
  </div>

  <form action="/timesheets/<%= @client.client_key %>" method="post" data-timesheet-target="form">
    <div class="bg-white rounded-xl border border-gray-200 overflow-x-auto">
      <table class="w-full text-sm min-w-[700px]">
        <thead class="bg-gray-50 border-b border-gray-200">
          <tr>
            <th class="px-2 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider w-28">Date</th>
            <th class="px-2 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider w-24">Item</th>
            <th class="px-2 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Description</th>
            <th class="px-2 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider w-16">Qty</th>
            <th class="px-2 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider w-20">Rate</th>
            <th class="px-2 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider w-24">Total</th>
            <th class="px-2 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider w-20">Invoiced</th>
            <th class="w-10"></th>
          </tr>
        </thead>
        <tbody data-timesheet-target="body">

          <%# Invoiced rows — read-only, greyed out %>
          <% @entries.select(&:invoiced).each do |e| %>
            <tr class="bg-gray-50 opacity-50">
              <td class="px-3 py-2 text-gray-500 whitespace-nowrap"><%= e.formatted_service_date %></td>
              <td class="px-3 py-2 text-gray-500"><%= e.item %></td>
              <td class="px-3 py-2 text-gray-400"><%= e.desc %></td>
              <td class="px-3 py-2 text-gray-500"><%= e.qty %></td>
              <td class="px-3 py-2 text-gray-500">$<%= e.formatted_cost %></td>
              <td class="px-3 py-2 text-right text-gray-500">$<%= e.formatted_line_total %></td>
              <td class="px-3 py-2 text-center">
                <span class="px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-700">Yes</span>
              </td>
              <td></td>
            </tr>
          <% end %>

          <%# Editable rows %>
          <% @entries.reject(&:invoiced).each_with_index do |e, i| %>
            <tr data-ts-row class="hover:bg-gray-50">
              <input type="hidden" name="entries[<%= i %>][id]" value="<%= e.id %>">
              <td class="px-2 py-1.5">
                <input type="text" name="entries[<%= i %>][service_date]" value="<%= e.formatted_service_date %>"
                  placeholder="MM/DD/YYYY"
                  class="w-full px-2 py-1 border border-gray-300 rounded text-sm focus:outline-none focus:ring-1 focus:ring-slate-500">
              </td>
              <td class="px-2 py-1.5">
                <input type="text" name="entries[<%= i %>][item]" value="<%= e.item %>"
                  placeholder="Item"
                  class="w-full px-2 py-1 border border-gray-300 rounded text-sm focus:outline-none focus:ring-1 focus:ring-slate-500">
              </td>
              <td class="px-2 py-1.5">
                <input type="text" name="entries[<%= i %>][desc]" value="<%= e.desc %>"
                  placeholder="Description"
                  class="w-full px-2 py-1 border border-gray-300 rounded text-sm focus:outline-none focus:ring-1 focus:ring-slate-500">
              </td>
              <td class="px-2 py-1.5">
                <input type="number" name="entries[<%= i %>][qty]" value="<%= e.qty %>" step="0.5" min="0"
                  placeholder="0"
                  data-action="input->timesheet#updateTotal"
                  data-ts-qty
                  class="w-full px-2 py-1 border border-gray-300 rounded text-sm focus:outline-none focus:ring-1 focus:ring-slate-500">
              </td>
              <td class="px-2 py-1.5">
                <input type="text" name="entries[<%= i %>][cost]" value="<%= e.formatted_cost %>"
                  placeholder="0.00"
                  data-action="input->timesheet#updateTotal"
                  data-ts-cost
                  class="w-full px-2 py-1 border border-gray-300 rounded text-sm focus:outline-none focus:ring-1 focus:ring-slate-500">
              </td>
              <td class="px-2 py-1.5 text-right text-sm text-gray-700 font-medium" data-ts-total>
                $<%= e.formatted_line_total %>
              </td>
              <td class="px-2 py-1.5 text-center">
                <span class="px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-500">No</span>
              </td>
              <td class="px-2 py-1.5 text-center">
                <input type="hidden" name="delete_entries[]" value="<%= e.id %>" disabled data-ts-delete>
                <button type="button" data-action="timesheet#removeRow"
                  class="h-8 min-w-[2rem] text-gray-400 hover:text-red-500 text-xs transition-colors cursor-pointer">&times;</button>
              </td>
            </tr>
          <% end %>

        </tbody>
      </table>
    </div>

    <div class="flex items-center justify-between mt-3">
      <button type="button" data-action="timesheet#addRow"
        class="px-3 py-2 bg-white border border-gray-300 hover:border-slate-500 text-xs font-medium rounded transition-colors cursor-pointer">
        + Add Row
      </button>
      <button type="submit"
        class="px-5 py-2 bg-slate-700 hover:bg-slate-800 text-white text-sm font-medium rounded-md transition-colors cursor-pointer">
        Save
      </button>
    </div>
  </form>

  <!-- New row template -->
  <template data-timesheet-target="rowTemplate">
    <%== erb :'timesheets/_row' %>
  </template>

</div>
