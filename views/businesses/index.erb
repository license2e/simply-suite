<div class="max-w-2xl mx-auto mt-12">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-semibold">Choose a business</h1>
    <a href="/businesses/new"
      class="px-4 py-2 bg-slate-700 hover:bg-slate-800 text-white text-sm font-medium rounded-md transition-colors">+ New business</a>
  </div>
  <ul class="bg-white rounded-xl border border-gray-200 divide-y divide-gray-100">
    <% @businesses.each do |b| %>
      <li class="flex items-center justify-between px-5 py-3">
        <span class="text-sm text-gray-900"><%= b.name %></span>
        <div class="flex items-center gap-4">
          <a href="/businesses/<%= b.slug %>/edit" class="text-sm text-slate-600 hover:text-slate-900">Edit</a>
          <form method="post" action="/businesses/<%= b.slug %>/select">
            <button class="text-sm text-blue-600 hover:underline" type="submit">Open &rarr;</button>
          </form>
        </div>
      </li>
    <% end %>
  </ul>
</div>
