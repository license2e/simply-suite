<div class="max-w-2xl space-y-8">

  <!-- Company / From -->
  <section>
    <h2 class="text-sm font-semibold text-gray-700 uppercase tracking-wider mb-3">From</h2>
    <form action="/settings/company" method="post" class="bg-white rounded-xl border border-gray-200 divide-y divide-gray-100">
      <% [
        ['Company',  'name',    'text',  @company.name],
        ['Contact',  'contact', 'text',  @company.contact],
        ['Email',    'email',   'email', @company.email],
        ['Street',   'street',  'text',  @company.street],
        ['City',     'city',    'text',  @company.city],
        ['State',    'state',   'text',  @company.state],
        ['ZIP',      'zip',     'text',  @company.zip],
      ].each do |label, field, type, val| %>
        <div class="px-5 py-4 flex items-center gap-4">
          <label class="w-32 text-xs font-medium text-gray-500 uppercase tracking-wider flex-shrink-0"><%= label %></label>
          <input type="<%= type %>" name="company[<%= field %>]" value="<%= val %>"
            class="flex-1 px-3 py-1.5 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-slate-500 focus:border-slate-500">
        </div>
      <% end %>
      <div class="px-5 py-4">
        <button type="submit"
          class="px-5 py-2 bg-slate-700 hover:bg-slate-800 text-white text-sm font-medium rounded-md transition-colors">Save</button>
      </div>
    </form>
  </section>

  <!-- Logo -->
  <section>
    <h2 class="text-sm font-semibold text-gray-700 uppercase tracking-wider mb-3">Invoice Logo</h2>
    <div class="bg-white rounded-xl border border-gray-200 p-5 space-y-4">
      <% if @logo_url %>
        <div class="p-3 bg-gray-50 rounded-lg inline-block">
          <img src="<%= @logo_url %>" alt="Logo" class="max-h-16 max-w-xs object-contain">
        </div>
      <% else %>
        <p class="text-sm text-gray-400 italic">No logo uploaded yet.</p>
      <% end %>
      <form action="/settings/logo" method="post" enctype="multipart/form-data">
        <div class="flex items-center gap-3">
          <input type="file" name="logo" accept="image/*"
            class="text-sm text-gray-600
              file:mr-3 file:px-3 file:py-1.5 file:rounded-md
              file:border file:border-gray-300 file:text-xs file:font-medium
              file:bg-white file:text-gray-700 hover:file:border-gray-400 file:cursor-pointer">
          <button type="submit"
            class="px-4 py-1.5 bg-slate-700 hover:bg-slate-800 text-white text-xs font-medium rounded-md flex-shrink-0 transition-colors">Upload</button>
        </div>
        <p class="mt-2 text-xs text-gray-400">PNG recommended. Shown on invoices and PDF exports.</p>
      </form>
    </div>
  </section>

</div>
