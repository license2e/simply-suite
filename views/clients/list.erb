<div class="flex items-center justify-between mb-5">
  <div></div>
  <a href="/clients/create"
    class="px-4 py-2 bg-slate-700 hover:bg-slate-800 text-white text-sm font-medium rounded-md transition-colors">
    New Client
  </a>
</div>

<div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
  <% if @clients.empty? %>
    <p class="p-8 text-center text-sm text-gray-500">No clients yet. <a href="/clients/create" class="underline text-slate-600">Create one.</a></p>
  <% else %>
    <table class="w-full text-sm">
      <thead class="bg-gray-50 border-b border-gray-200">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Contact</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Email</th>
          <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @clients.each do |client| %>
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-3 font-medium text-gray-900"><%= client.name %></td>
            <td class="px-4 py-3 text-gray-600"><%= client.contact %></td>
            <td class="px-4 py-3 text-gray-600"><%= client.email %></td>
            <td class="px-4 py-3 text-right space-x-3">
              <a href="/invoices/<%= client.slug %>" class="text-xs text-slate-600 hover:text-slate-900 font-medium">Invoices</a>
              <a href="/clients/view/<%= client.slug %>" class="text-xs text-slate-600 hover:text-slate-900 font-medium">View</a>
              <a href="/clients/edit/<%= client.slug %>" class="text-xs text-slate-600 hover:text-slate-900 font-medium">Edit</a>
              <a href="/clients/delete/<%= client.slug %>"
                onclick="return confirm('Delete <%= client.name %> and ALL their invoices? This cannot be undone.')"
                class="text-xs text-red-400 hover:text-red-600 font-medium">Delete</a>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
</div>
<%== erb :'_pagination' %>
