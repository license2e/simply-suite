<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Invoice <%= @invoice.client.client_prefix %>-<%= @invoice.num %></title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, Helvetica, Arial, sans-serif; font-size: 13px; color: #333; background: #eee; }

    .page { background: white; max-width: 760px; margin: 30px auto; padding: 56px; box-shadow: 0 2px 12px rgba(0,0,0,0.12); }

    .header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 48px; }
    .company-name { font-size: 15px; font-weight: 600; margin-bottom: 5px; }
    .company-detail { color: #555; line-height: 1.6; }

    .invoice-meta { text-align: right; }
    .invoice-title { font-size: 24px; font-weight: 700; letter-spacing: 1px; color: #111; margin-bottom: 14px; }
    .meta-row { margin-bottom: 3px; color: #555; }
    .meta-row strong { color: #111; }
    .balance-box { display: inline-block; margin-top: 14px; background: #f8f8f8; border: 1px solid #e0e0e0; border-radius: 6px; padding: 10px 16px; text-align: right; }
    .balance-label { font-size: 10px; text-transform: uppercase; letter-spacing: 0.8px; color: #888; margin-bottom: 4px; }
    .balance-amount { font-size: 20px; font-weight: 700; color: #111; }

    .bill-to { margin-bottom: 36px; }
    .section-label { font-size: 10px; text-transform: uppercase; letter-spacing: 1px; color: #aaa; font-weight: 600; margin-bottom: 8px; }
    .client-name { font-size: 14px; font-weight: 600; margin-bottom: 4px; }
    .client-detail { color: #555; line-height: 1.6; }

    table { width: 100%; border-collapse: collapse; margin-bottom: 24px; }
    thead th { padding: 8px 10px; font-size: 10px; text-transform: uppercase; letter-spacing: 0.6px; color: #888; font-weight: 600; border-bottom: 2px solid #e8e8e8; background: #fafafa; text-align: left; }
    thead th.r { text-align: right; }
    tbody td { padding: 11px 10px; border-bottom: 1px solid #f2f2f2; vertical-align: top; color: #333; }
    tbody td.r { text-align: right; }
    tbody td.muted { color: #666; }
    tbody tr:last-child td { border-bottom: none; }

    .totals-wrap { display: flex; justify-content: flex-end; margin-bottom: 40px; }
    .totals { min-width: 230px; }
    .totals-row { display: flex; justify-content: space-between; padding: 5px 0; color: #555; }
    .totals-row.divider { border-top: 1px solid #e8e8e8; margin-top: 4px; padding-top: 8px; color: #111; font-weight: 600; }
    .totals-row.final { background: #f5f5f5; border-radius: 5px; padding: 9px 12px; margin-top: 6px; font-weight: 700; font-size: 14px; color: #111; }
    .totals-label { margin-right: 24px; }

    .footer { display: grid; grid-template-columns: 1fr 1fr; gap: 28px; padding-top: 24px; border-top: 1px solid #eee; }
    .footer-label { font-size: 10px; text-transform: uppercase; letter-spacing: 0.8px; color: #aaa; font-weight: 600; margin-bottom: 6px; }
    .footer-value { color: #444; line-height: 1.6; }

    @media print {
      body { background: white; }
      .page { box-shadow: none; margin: 0; padding: 36px; }
    }
  </style>
</head>
<body>

<div class="page">
  <div class="header">
    <div>
      <% if @company %>
        <p class="company-name"><%= @company.name %></p>
        <% unless @company.contact.to_s.empty? %><p class="company-detail"><%= @company.contact %></p><% end %>
        <% unless @company.street.to_s.empty? %><p class="company-detail"><%= @company.street %></p><% end %>
        <% unless @company.city.to_s.empty? %><p class="company-detail"><%= @company.city_state_zip %></p><% end %>
        <% unless @company.email.to_s.empty? %><p class="company-detail"><%= @company.email %></p><% end %>
      <% end %>
    </div>
    <div class="invoice-meta">
      <% if @logo_url %>
        <img src="<%= @logo_url %>" alt="" style="max-width:160px;max-height:64px;object-fit:contain;display:block;margin-left:auto;margin-bottom:16px;">
      <% end %>
      <p class="invoice-title">INVOICE</p>
      <p class="meta-row"><strong><%= @invoice.client.client_prefix %>-<%= @invoice.num %></strong></p>
      <p class="meta-row"><%= @invoice.formatted_invoice_date %></p>
      <div class="balance-box">
        <p class="balance-label">Balance Due</p>
        <p class="balance-amount">$<%= @invoice.formatted_final_amount %> USD</p>
      </div>
    </div>
  </div>

  <div class="bill-to">
    <p class="section-label">Bill To</p>
    <p class="client-name"><%= @invoice.client.name %></p>
    <% unless @invoice.client.contact.to_s.empty? %><p class="client-detail"><%= @invoice.client.contact %></p><% end %>
    <% unless @invoice.client.street.to_s.empty? %>
      <p class="client-detail"><%= @invoice.client.street %><% unless @invoice.client.street2.to_s.empty? %> <%= @invoice.client.street2 %><% end %></p>
    <% end %>
    <% unless @invoice.client.city.to_s.empty? %>
      <p class="client-detail"><%= @invoice.client.city %>, <%= @invoice.client.state %> <%= @invoice.client.zip %></p>
    <% end %>
    <% unless @invoice.client.email.to_s.empty? %><p class="client-detail"><%= @invoice.client.email %></p><% end %>
  </div>

  <table>
    <thead>
      <tr>
        <th>Item</th>
        <th>Description</th>
        <th class="r">Date</th>
        <th class="r">Unit Cost</th>
        <th class="r">Qty</th>
        <th class="r">Line Total</th>
      </tr>
    </thead>
    <tbody>
      <% @invoice.services.each do |s| %>
        <tr>
          <td><%= s.item %></td>
          <td class="muted"><%= s.desc %></td>
          <td class="r muted" style="white-space:nowrap"><%= s.formatted_service_date %></td>
          <td class="r">$<%= s.formatted_cost %></td>
          <td class="r"><%= s.qty %></td>
          <td class="r" style="font-weight:500">$<%= s.formatted_line_total %></td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <div class="totals-wrap">
    <div class="totals">
      <% if @invoice.total_discount.to_f > 0 %>
        <div class="totals-row">
          <span class="totals-label">Subtotal</span>
          <span>$<%= @invoice.formatted_total_amount %></span>
        </div>
        <div class="totals-row">
          <span class="totals-label">Discount (<%= @invoice.formatted_discount_percentage %>%)</span>
          <span>-$<%= @invoice.formatted_total_discount %></span>
        </div>
        <div class="totals-row divider">
          <span class="totals-label">Invoice Total</span>
          <span>$<%= @invoice.formatted_discount_total_amount %></span>
        </div>
      <% else %>
        <div class="totals-row divider">
          <span class="totals-label">Invoice Total</span>
          <span>$<%= @invoice.formatted_total_amount %></span>
        </div>
      <% end %>
      <% if @invoice.amount_paid.to_f > 0 %>
        <div class="totals-row">
          <span class="totals-label">Amount Paid</span>
          <span>-$<%= @invoice.formatted_amount_paid %></span>
        </div>
      <% end %>
      <div class="totals-row final">
        <span>Balance Due</span>
        <span>$<%= @invoice.formatted_final_amount %> USD</span>
      </div>
    </div>
  </div>

  <div class="footer">
    <div>
      <p class="footer-label">Terms</p>
      <p class="footer-value"><%= @invoice.formatted_terms %></p>
    </div>
    <div>
      <p class="footer-label">Notes</p>
      <p class="footer-value"><%= @invoice.formatted_notes %></p>
    </div>
  </div>
</div>

</body>
</html>
